    <p class="cm-sub">Introduce el código que<br>te ha facilitado el equipo Moira</p>
    <input type="password" id="code-input" placeholder="····" maxlength="4"
      onkeydown="if(event.key==='Enter')checkCode(); if(event.key==='Escape')closeCode();"
      autocomplete="off" inputmode="numeric">
    <span id="code-error"></span>
    <button id="code-submit" onclick="checkCode()">Acceder</button>
    <button id="code-cancel" onclick="closeCode()">Cancelar</button>
