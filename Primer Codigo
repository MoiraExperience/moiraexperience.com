// SELECT SINGLE (radio-like)
function selectSingle(el) {
  const group = el.dataset.group;
  const container = el.closest('.options, .range-opts, .size-grid');
  if (!container) return;
  container.querySelectorAll('[data-group="' + group + '"]').forEach(o => o.classList.remove('selected'));
