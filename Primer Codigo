<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MOIRA EXPERIENCE — 13/14 JUNIO · BARCELONA</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@300;400;600;700&family=Barlow:wght@300;400&display=swap" rel="stylesheet">
<style>
  :root { --black:#080808; --white:#f0ede8; --grey:#b8b4ae; --accent:#c8a96e; --mid:#141414; }
  *,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior:smooth; }
  body { background:var(--black); color:var(--white); font-family:'Barlow',sans-serif; font-weight:300; overflow-x:hidden; }
  body::before { content:''; position:fixed; inset:0; background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E"); pointer-events:none; z-index:9000; opacity:0.5; }

  nav { position:fixed; top:0; left:0; right:0; z-index:500; display:flex; justify-content:space-between; align-items:center; padding:22px 52px; transition:background 0.4s,border-bottom 0.4s; }
  nav.scrolled { background:rgba(8,8,8,0.96); border-bottom:1px solid rgba(200,169,110,0.12); backdrop-filter:blur(8px); }
  .nav-logo { font-family:'Bebas Neue',sans-serif; font-size:22px; letter-spacing:5px; color:var(--accent); text-decoration:none; }
  .nav-links { display:flex; gap:36px; list-style:none; align-items:center; }
  .nav-links a { font-family:'Barlow Condensed',sans-serif; font-size:12px; letter-spacing:3px; text-transform:uppercase; color:var(--grey); text-decoration:none; transition:color 0.3s; }
  .nav-links a:hover { color:var(--accent); }
  .nav-cta { background:var(--accent)!important; color:var(--black)!important; padding:10px 24px!important; transition:opacity 0.3s!important; }
  .nav-cta:hover { opacity:0.82!important; }

  .hero { position:relative; height:100vh; display:flex; flex-direction:column; justify-content:flex-end; overflow:hidden; }
  .hero-bg { position:absolute; inset:0; background:linear-gradient(to bottom,rgba(8,8,8,0.25) 0%,rgba(8,8,8,0.05) 35%,rgba(8,8,8,0.78) 75%,var(--black) 100%),linear-gradient(160deg,#120808 0%,#080c08 55%,#080808 100%); }
  .terrain { position:absolute; inset:0; overflow:hidden; pointer-events:none; }
  .terrain svg { position:absolute; bottom:0; left:0; width:100%; height:55%; opacity:0.07; }
  .particles { position:absolute; inset:0; overflow:hidden; pointer-events:none; }
  .particle { position:absolute; border-radius:50%; background:var(--accent); animation:rise linear infinite; opacity:0; }
  @keyframes rise { 0%{transform:translateY(100vh);opacity:0;} 8%{opacity:0.7;} 92%{opacity:0.2;} 100%{transform:translateY(-5vh) translateX(20px);opacity:0;} }
  .hero-content { position:relative; z-index:10; padding:0 52px 90px; }
  .hero-label { font-family:'Barlow Condensed',sans-serif; font-size:12px; letter-spacing:7px; color:var(--accent); text-transform:uppercase; margin-bottom:18px; animation:fadeUp 1s ease 0.3s both; }
  .hero-title { font-family:'Bebas Neue',sans-serif; font-size:clamp(90px,17vw,230px); line-height:0.86; animation:fadeUp 1s ease 0.55s both; }
  .hero-title .outline { display:block; color:transparent; -webkit-text-stroke:1.5px rgba(240,237,232,0.35); }
  .hero-foot { display:flex; justify-content:space-between; align-items:flex-end; margin-top:44px; animation:fadeUp 1s ease 0.85s both; }
  .hero-sub { font-family:'Barlow Condensed',sans-serif; font-size:14px; letter-spacing:3px; color:var(--grey); text-transform:uppercase; line-height:1.9; }
  .hero-sub strong { color:var(--accent); display:block; }
  .btn-primary { display:inline-block; padding:18px 52px; border:1px solid var(--accent); font-family:'Barlow Condensed',sans-serif; font-size:13px; letter-spacing:4px; text-transform:uppercase; color:var(--accent); text-decoration:none; position:relative; overflow:hidden; transition:color 0.4s; }
  .btn-primary::before { content:''; position:absolute; inset:0; background:var(--accent); transform:translateX(-101%); transition:transform 0.4s cubic-bezier(0.76,0,0.24,1); }
  .btn-primary:hover { color:var(--black); }
  .btn-primary:hover::before { transform:translateX(0); }
  .btn-primary span { position:relative; z-index:1; }
  .scroll-hint { position:absolute; bottom:38px; left:50%; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:10px; animation:fadeUp 1s ease 1.3s both; pointer-events:none; }
  .scroll-line { width:1px; height:56px; background:linear-gradient(to bottom,var(--accent),transparent); animation:blink 2s ease infinite; }
  .scroll-hint p { font-family:'Barlow Condensed',sans-serif; font-size:9px; letter-spacing:4px; color:var(--grey); text-transform:uppercase; }
  @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0.25;} }
  @keyframes fadeUp { from{opacity:0;transform:translateY(28px);} to{opacity:1;transform:translateY(0);} }

  .marquee { background:var(--accent); padding:15px 0; overflow:hidden; white-space:nowrap; }
  .marquee-inner { display:inline-block; animation:scroll 22s linear infinite; font-family:'Bebas Neue',sans-serif; font-size:17px; letter-spacing:6px; color:var(--black); }
  @keyframes scroll { 0%{transform:translateX(0);} 100%{transform:translateX(-50%);} }

  section { padding:110px 52px; }
  .sec-label { font-family:'Barlow Condensed',sans-serif; font-size:11px; letter-spacing:5px; color:var(--accent); text-transform:uppercase; margin-bottom:56px; display:flex; align-items:center; gap:18px; }
  .sec-label::before { content:''; width:36px; height:1px; background:var(--accent); }
  .big-heading { font-family:'Bebas Neue',sans-serif; font-size:clamp(52px,7vw,96px); line-height:0.9; margin-bottom:36px; }
  .body-text { font-size:16px; line-height:1.95; color:var(--grey); }

  .about-wrap { display:grid; grid-template-columns:1fr 1fr; gap:100px; align-items:center; }
  .card-stats { background:var(--mid); border:1px solid rgba(200,169,110,0.12); padding:56px 44px; position:relative; }
  .card-stats::before { content:''; position:absolute; top:-1px; left:44px; width:72px; height:2px; background:var(--accent); }
  .stat-row { display:flex; justify-content:space-between; padding:26px 0; border-bottom:1px solid rgba(255,255,255,0.055); }
  .stat-row:last-child { border-bottom:none; }
  .stat-n { font-family:'Bebas Neue',sans-serif; font-size:52px; color:var(--accent); line-height:1; }
  .stat-l { font-family:'Barlow Condensed',sans-serif; font-size:11px; letter-spacing:3px; color:var(--grey); text-transform:uppercase; align-self:flex-end; padding-bottom:6px; }

  .values { background:var(--mid); }
  .values-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:2px; margin-top:60px; }
  .val-card { background:var(--black); padding:60px 44px; position:relative; overflow:hidden; transition:background 0.4s; }
  .val-card:hover { background:#0f0f0f; }
  .val-card::after { content:''; position:absolute; bottom:0; left:0; right:0; height:2px; background:var(--accent); transform:scaleX(0); transition:transform 0.4s cubic-bezier(0.76,0,0.24,1); }
  .val-card:hover::after { transform:scaleX(1); }
  .val-icon { font-size:32px; margin-bottom:28px; display:block; }
  .val-title { font-family:'Bebas Neue',sans-serif; font-size:30px; letter-spacing:1px; margin-bottom:16px; }
  .val-desc { font-size:14px; line-height:1.85; color:var(--grey); }

  .team-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:2px; margin-top:70px; }
  .team-card { position:relative; overflow:hidden; aspect-ratio:3/4; background:var(--mid); }
  .team-avatar { position:absolute; inset:0; background-size:cover; background-position:center top; filter:grayscale(35%); transition:transform 0.6s cubic-bezier(0.25,0.46,0.45,0.94),filter 0.4s; }
  .team-card:hover .team-avatar { transform:scale(1.04); filter:grayscale(0%); }
  .team-overlay { position:absolute; inset:0; background:linear-gradient(to top,rgba(8,8,8,0.94) 0%,rgba(8,8,8,0.25) 55%,transparent 100%); display:flex; flex-direction:column; justify-content:flex-end; padding:40px 36px; transition:background 0.4s; }
  .team-card:hover .team-overlay { background:linear-gradient(to top,rgba(8,8,8,0.97) 0%,rgba(8,8,8,0.5) 55%,rgba(8,8,8,0.1) 100%); }
  .team-role { font-family:'Barlow Condensed',sans-serif; font-size:11px; letter-spacing:4px; color:var(--accent); text-transform:uppercase; margin-bottom:10px; }
  .team-name { font-family:'Bebas Neue',sans-serif; font-size:38px; letter-spacing:1px; line-height:1; margin-bottom:14px; }
  .team-bio { font-size:13px; color:var(--grey); line-height:1.65; max-height:0; overflow:hidden; opacity:0; transition:max-height 0.5s ease,opacity 0.4s; }
  .team-card:hover .team-bio { max-height:80px; opacity:1; }
  .btn-gold { display:inline-block; padding:22px 88px; background:var(--accent); font-family:'Bebas Neue',sans-serif; font-size:22px; letter-spacing:5px; color:var(--black); text-decoration:none; position:relative; z-index:1; transition:transform 0.3s,box-shadow 0.3s; }
  .btn-gold:hover { transform:translateY(-3px); box-shadow:0 18px 50px rgba(200,169,110,0.28); }

  footer { background:var(--mid); padding:52px; display:flex; justify-content:space-between; align-items:center; border-top:1px solid rgba(255,255,255,0.06); flex-wrap:wrap; gap:24px; }
  .footer-logo { font-family:'Bebas Neue',sans-serif; font-size:24px; letter-spacing:4px; color:var(--accent); }
  .footer-links { display:flex; gap:36px; list-style:none; flex-wrap:wrap; }
  .footer-links a { font-family:'Barlow Condensed',sans-serif; font-size:12px; letter-spacing:3px; color:var(--grey); text-decoration:none; text-transform:uppercase; transition:color 0.3s; }
  .footer-links a:hover { color:var(--accent); }
  .footer-copy { font-family:'Barlow Condensed',sans-serif; font-size:11px; letter-spacing:2px; color:rgba(184,180,174,0.38); text-transform:uppercase; }

  #cookie-banner { display:none; position:fixed; bottom:0; left:0; right:0; z-index:9999; background:rgba(20,20,20,0.97); border-top:1px solid rgba(200,169,110,0.2); padding:24px 52px; align-items:center; justify-content:space-between; gap:24px; flex-wrap:wrap; backdrop-filter:blur(12px); }
  .cookie-text { font-family:'Barlow Condensed',sans-serif; font-size:14px; letter-spacing:1px; color:var(--grey); max-width:640px; line-height:1.6; }
  .cookie-text a { color:var(--accent); text-decoration:none; }
  .cookie-text a:hover { text-decoration:underline; }
  .cookie-btns { display:flex; gap:12px; flex-shrink:0; }
  .btn-cookie-accept { font-family:'Barlow Condensed',sans-serif; font-size:12px; letter-spacing:3px; text-transform:uppercase; background:var(--accent); color:var(--black); border:none; padding:12px 28px; cursor:pointer; transition:opacity 0.3s; }
  .btn-cookie-accept:hover { opacity:0.85; }
  .btn-cookie-reject { font-family:'Barlow Condensed',sans-serif; font-size:12px; letter-spacing:3px; text-transform:uppercase; background:transparent; color:var(--grey); border:1px solid rgba(184,180,174,0.3); padding:12px 28px; cursor:pointer; transition:color 0.3s,border-color 0.3s; }
  .btn-cookie-reject:hover { color:var(--white); border-color:var(--white); }

  .reveal { opacity:0; transform:translateY(36px); transition:opacity 0.8s ease,transform 0.8s ease; }
  .reveal.visible { opacity:1; transform:translateY(0); }

  @media (max-width:768px) {
    nav { padding:20px 24px; }
    .nav-links { display:none; }
    section { padding:80px 24px; }
    .hero-content { padding:0 24px 70px; }
    .hero-foot { flex-direction:column; align-items:flex-start; gap:28px; }
    .about-wrap { grid-template-columns:1fr; gap:48px; }
    .values-grid { grid-template-columns:1fr; }
    .team-grid { grid-template-columns:1fr; }
    footer { flex-direction:column; text-align:center; padding:40px 24px; }
    .footer-links { justify-content:center; }
    #cookie-banner { padding:20px 24px; flex-direction:column; align-items:flex-start; }
  }

  :root {
    --black: #080808; --white: #f0ede8; --grey: #9a9690;
    --accent: #c8a96e; --mid: #131313; --card: #1c1c1c;
    --border: rgba(200,169,110,0.15); --red: #8b2a2a;
  }
  *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior:smooth; }
  #form-panel-body {
    background: var(--black); color: var(--white);
    font-family: 'Barlow', sans-serif; font-weight:300;
    min-height:100vh; overflow-x:hidden;
  }

  /* NOISE */
  body::before {
    content:''; position:fixed; inset:0; pointer-events:none; z-index:9999; opacity:0.35;
    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  }

  /* HEADER */
  header {
    position:fixed; top:0; left:0; right:0; z-index:100;
    display:flex; justify-content:space-between; align-items:center;
    padding:18px 48px;
    background:rgba(8,8,8,0.95); border-bottom:1px solid var(--border);
    backdrop-filter:blur(10px);
  }
  .logo { font-family:'Bebas Neue',sans-serif; font-size:20px; letter-spacing:5px; color:var(--accent); text-decoration:none; }
  .header-tag { font-family:'Barlow Condensed',sans-serif; font-size:11px; letter-spacing:4px; color:var(--grey); text-transform:uppercase; }

  /* PROGRESS */
  #form-panel .progress-wrap-bar {
    position:fixed; top:61px; left:0; right:0; z-index:99;
    height:2px; background:rgba(255,255,255,0.06);
  }
  #form-panel .progress-wrap-fill {
    height:100%; background:var(--accent);
    transition:width 0.6s cubic-bezier(0.76,0,0.24,1);
  }

  /* MAIN */
  #form-panel main {
    min-height:100vh; padding:120px 48px 80px;
    display:flex; flex-direction:column; align-items:center;
  }

  /* STEP */
  #form-panel .step { display:none; width:100%; max-width:780px; animation:stepIn 0.5s ease both; }
  #form-panel .step.active { display:block; }
  @keyframes stepIn { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }

  #form-panel .step-num {
    font-family:'Barlow Condensed',sans-serif; font-size:11px; letter-spacing:5px;
    color:var(--accent); text-transform:uppercase; margin-bottom:16px;
    display:flex; align-items:center; gap:14px;
  }
  #form-panel .step-num::before { content:''; width:32px; height:1px; background:var(--accent); }
  #form-panel .step-question {
    font-family:'Bebas Neue',sans-serif; font-size:clamp(36px,6vw,68px);
    line-height:0.92; margin-bottom:14px;
  }
  #form-panel .step-hint {
    font-family:'Barlow',sans-serif; font-size:14px; color:var(--grey);
    line-height:1.7; margin-bottom:48px; max-width:560px;
  }

  /* OPTIONS GRID */
  .options { display:grid; gap:10px; }
  .options.cols-2 { grid-template-columns:repeat(2,1fr); }
  .options.cols-3 { grid-template-columns:repeat(3,1fr); }
  .options.cols-4 { grid-template-columns:repeat(4,1fr); }

  .opt {
    background:var(--card); border:1px solid rgba(255,255,255,0.07);
    padding:22px 28px; cursor:pointer;
    transition:border-color 0.25s, background 0.25s, transform 0.2s;
    position:relative; overflow:hidden; user-select:none;
  }
  .opt:hover { border-color:rgba(200,169,110,0.4); background:#222; }
  .opt.selected { border-color:var(--accent); background:rgba(200,169,110,0.08); }
  .opt.selected::after {
    content:'✓'; position:absolute; top:12px; right:16px;
    font-family:'Barlow Condensed',sans-serif; font-size:14px;
    color:var(--accent); letter-spacing:0;
  }
  .opt-icon { font-size:24px; margin-bottom:12px; display:block; }
  .opt-label {
    font-family:'Barlow Condensed',sans-serif; font-size:16px;
    letter-spacing:1px; font-weight:600; text-transform:uppercase;
    color:var(--white); margin-bottom:4px;
  }
  .opt-desc { font-size:12px; color:var(--grey); line-height:1.5; }

  /* COMPACT OPTIONS (tags) */
  .tags { display:flex; flex-wrap:wrap; gap:10px; }
  .tag {
    padding:12px 22px; border:1px solid rgba(255,255,255,0.1);
    font-family:'Barlow Condensed',sans-serif; font-size:13px;
    letter-spacing:2px; text-transform:uppercase; color:var(--grey);
    cursor:pointer; transition:all 0.25s; background:var(--card);
  }
  .tag:hover { border-color:rgba(200,169,110,0.4); color:var(--white); }
  .tag.selected { border-color:var(--accent); color:var(--accent); background:rgba(200,169,110,0.07); }

  /* SLIDER STYLE OPTIONS (size/range) */
  .size-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(80px,1fr)); gap:8px; }
  .size-opt {
    aspect-ratio:1; display:flex; align-items:center; justify-content:center;
    border:1px solid rgba(255,255,255,0.08); background:var(--card);
    font-family:'Bebas Neue',sans-serif; font-size:22px; letter-spacing:2px;
    cursor:pointer; transition:all 0.25s; color:var(--grey);
  }
  .size-opt:hover { border-color:rgba(200,169,110,0.4); color:var(--white); }
  .size-opt.selected { border-color:var(--accent); color:var(--accent); background:rgba(200,169,110,0.08); }

  /* RANGE SELECTOR */
  .range-opts { display:grid; grid-template-columns:repeat(auto-fit,minmax(100px,1fr)); gap:8px; }
  .range-opt {
    padding:18px 12px; text-align:center; border:1px solid rgba(255,255,255,0.08);
    background:var(--card); cursor:pointer; transition:all 0.25s;
  }
  .range-opt:hover { border-color:rgba(200,169,110,0.4); }
  .range-opt.selected { border-color:var(--accent); background:rgba(200,169,110,0.08); }
  .range-val { font-family:'Bebas Neue',sans-serif; font-size:28px; color:var(--accent); display:block; }
  .range-lbl { font-family:'Barlow Condensed',sans-serif; font-size:10px; letter-spacing:2px; color:var(--grey); text-transform:uppercase; }

  /* TEXT INPUT (only for name) */
  .text-input {
    width:100%; background:var(--card); border:1px solid rgba(255,255,255,0.1);
    color:var(--white); font-family:'Bebas Neue',sans-serif; font-size:36px;
    letter-spacing:3px; padding:24px 28px; outline:none;
    transition:border-color 0.3s;
  }
  .text-input:focus { border-color:var(--accent); }
  .text-input::placeholder { color:rgba(255,255,255,0.15); }

  /* ALERT */
  .alert {
    background:rgba(139,42,42,0.15); border:1px solid rgba(139,42,42,0.4);
    padding:16px 20px; margin-top:12px;
    font-family:'Barlow Condensed',sans-serif; font-size:13px; letter-spacing:1px;
    color:#e07070; display:none;
  }
  .alert.show { display:block; }

  /* NAV BUTTONS */
  #form-panel .step-nav { display:flex; justify-content:space-between; align-items:center; margin-top:48px; }
  #form-panel .btn-back {
    font-family:'Barlow Condensed',sans-serif; font-size:12px; letter-spacing:3px;
    text-transform:uppercase; color:var(--grey); background:none; border:none;
    cursor:pointer; transition:color 0.3s; padding:0;
  }
  #form-panel .btn-back:hover { color:var(--white); }
  .btn-next {
    font-family:'Barlow Condensed',sans-serif; font-size:13px; letter-spacing:4px;
    text-transform:uppercase; color:var(--black); background:var(--accent);
    border:none; padding:18px 52px; cursor:pointer; transition:transform 0.3s, box-shadow 0.3s;
  }
  .btn-next:hover { transform:translateY(-2px); box-shadow:0 12px 40px rgba(200,169,110,0.25); }
  .btn-next:disabled { opacity:0.3; cursor:not-allowed; transform:none; box-shadow:none; }

  #form-panel .step-counter {
    font-family:'Barlow Condensed',sans-serif; font-size:12px; letter-spacing:3px;
    color:var(--grey); text-transform:uppercase;
  }

  /* DIVIDER */
  .divider { width:100%; height:1px; background:rgba(255,255,255,0.06); margin:32px 0; }

  /* SUMMARY */
  #step-summary .summary-grid { display:grid; grid-template-columns:1fr 1fr; gap:2px; margin-bottom:32px; }
  .sum-block { background:var(--card); padding:24px 28px; }
  .sum-key { font-family:'Barlow Condensed',sans-serif; font-size:10px; letter-spacing:4px; color:var(--grey); text-transform:uppercase; margin-bottom:8px; }
  .sum-val { font-family:'Bebas Neue',sans-serif; font-size:20px; letter-spacing:1px; color:var(--white); line-height:1.2; }

  #form-panel .btn-submit {
    width:100%; padding:24px; background:var(--accent);
    font-family:'Bebas Neue',sans-serif; font-size:24px; letter-spacing:5px;
    color:var(--black); border:none; cursor:pointer;
    transition:transform 0.3s, box-shadow 0.3s;
  }
  #form-panel .btn-submit:hover { transform:translateY(-3px); box-shadow:0 16px 48px rgba(200,169,110,0.3); }

  /* SUCCESS */
  #step-done { text-align:center; padding:40px 0; }
  .done-icon { font-size:64px; margin-bottom:28px; display:block; }
  .done-title { font-family:'Bebas Neue',sans-serif; font-size:clamp(48px,8vw,100px); line-height:0.9; margin-bottom:20px; }
