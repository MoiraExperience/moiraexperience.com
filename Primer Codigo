  const container = el.closest('.tags');

  if (exclusive) {
    // Deselect all others
    container.querySelectorAll('[data-group="' + group + '"]').forEach(t => t.classList.remove('selected'));
    el.classList.add('selected');
  } else {
    // Deselect exclusive "Ninguno" option if exists
    const noneTag = container.querySelector('[data-group="' + group + '"].selected[data-val*="Ninguna"], [data-group="' + group + '"].selected[data-val*="Ninguno"]');
    if (noneTag && noneTag !== el) noneTag.classList.remove('selected');
    el.classList.toggle('selected');

    // Enforce max 3 for personalidad
    if (group === 'personalidad') {
      const selected = container.querySelectorAll('.tag.selected');
      if (selected.length > 3) {
        el.classList.remove('selected');
        return;
      }
    }
  }

  // Update data array
  data[group] = Array.from(container.querySelectorAll('[data-group="' + group + '"].selected')).map(t => t.dataset.val);
  if (!Array.isArray(data[group])) data[group] = [data[group]];
}

// VALIDATION
function validate(step) {
  const alertEl = document.getElementById('alert-' + step);
  if (alertEl) alertEl.classList.remove('show');

  if (step === 1) {
    const n = document.getElementById('nombre').value.trim();
    data.nombre = n;
    if (!n) { alertEl.classList.add('show'); return false; }
    return true;
  }
  if (step === 2) {
    if (!data.edad || !data.sexo) { alertEl.classList.add('show'); return false; }
    return true;
  }
  if (step === 3) {
    if (!data.altura || !data.peso || !data.talla) { alertEl.classList.add('show'); return false; }
    return true;
  }
  if (step === 4) {
    if (!data.dieta) { alertEl.classList.add('show'); return false; }
    return true;
  }
  if (step === 5) {
    if (!data.forma) { alertEl.classList.add('show'); return false; }
    return true;
  }
  if (step === 6) {
    if (!data.nadar) { alertEl.classList.add('show'); return false; }
    return true;
  }
  if (step === 7) {
    if (!data['miedo-mayor']) { alertEl.classList.add('show'); return false; }
    return true;
  }
  if (step === 8) {
    if (!data.rol || !data.presion) { alertEl.classList.add('show'); return false; }
    return true;
  }
  if (step === 9) {
    if (!data.motivo || !data.grupo || !data.exp) { alertEl.classList.add('show'); return false; }
    return true;
  }
  return true;
}

// NAVIGATION
function showStep(n) {
  document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
  const target = n === 'done' ? document.getElementById('step-done')
               : n === 'summary' ? document.getElementById('step-summary')
               : document.getElementById('step-' + n);
  if (target) { target.classList.add('active'); window.scrollTo({ top: 0, behavior: 'smooth' }); }
}

function nextStep(from) {
  if (!validate(from)) return;
  if (from === 9) {
    buildSummary();
    showStep('summary');
    document.getElementById('form-progress').style.width = '95%';
    return;
  }
  currentStep = from + 1;
  updateProgress();
  showStep(currentStep);
}

function prevStep(from) {
  if (from === 10) {
    currentStep = 9;
    updateProgress();
    showStep(9);
    return;
  }
  currentStep = from - 1;
  updateProgress();
  showStep(currentStep);
}

