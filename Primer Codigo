// ── ACCESO CON CÓDIGO ──────────────────────────
var CODIGO = '1306';
var intentosFallidos = 0;

function askCode() {
  intentosFallidos = 0;
  var modal = document.getElementById('code-modal');
  if (!modal) { openFormPanel(); return; }
  modal.style.display = 'flex';
  modal.classList.add('open');
  var inp = document.getElementById('code-input');
  if (inp) { inp.value = ''; inp.focus(); }
  var err = document.getElementById('code-error');
  if (err) err.textContent = '';
}

function closeCode() {
  var modal = document.getElementById('code-modal');
  if (modal) { modal.classList.remove('open'); modal.style.display = 'none'; }
  var inp = document.getElementById('code-input');
  if (inp) inp.value = '';
}

function checkCode() {
  var inp = document.getElementById('code-input');
  var err = document.getElementById('code-error');
  var val = inp ? inp.value.trim() : '';
  if (val === CODIGO) {
    closeCode();
    openFormPanel();
  } else {
    intentosFallidos++;
    if (err) {
      err.textContent = intentosFallidos >= 3
        ? 'Demasiados intentos. Contacta con el equipo Moira.'
        : 'Código incorrecto. Inténtalo de nuevo.';
    }
    if (inp) { inp.value = ''; inp.focus(); }
    // Shake
    var box = document.getElementById('code-box');
    if (box) {
      box.style.transition = 'none';
      box.style.transform = 'translateX(-10px)';
      setTimeout(function(){ box.style.transform = 'translateX(10px)'; }, 80);
      setTimeout(function(){ box.style.transform = 'translateX(-6px)'; }, 160);
      setTimeout(function(){ box.style.transform = 'translateX(0)'; box.style.transition = ''; }, 240);
    }
  }
}

