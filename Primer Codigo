    { k: 'Motivación', v: data.motivo },
    { k: 'Viene', v: data.grupo },
    { k: 'Experiencia previa', v: data.exp },
  ];

  const grid = document.getElementById('summary-content');
  grid.innerHTML = items.map(i => `
    <div class="sum-block">
      <div class="sum-key">${i.k}</div>
