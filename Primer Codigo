function downloadCSV() {
  const headers = [
    'Nombre','Edad','Sexo','Altura','Peso','Talla',
    'Dieta','Alergias','Forma fisica','Deportes',
    'Salud','Natacion','Incomodidades','Mayor miedo en reto',
    'Rol en equipo','Bajo presion','Personalidad',
    'Motivacion','Viene','Experiencia previa','Fecha envio'
  ];
  const now = new Date().toLocaleString('es-ES');
  const values = [
    data.nombre, data.edad, data.sexo, data.altura, data.peso, data.talla,
    data.dieta,
    data.alergias.length ? data.alergias.join(' | ') : 'Ninguna',
    data.forma,
    data.deporte.length ? data.deporte.join(' | ') : 'Ninguno',
    data.salud.length ? data.salud.join(' | ') : 'Sin condiciones',
    data.nadar,
    data.miedos.length ? data.miedos.join(' | ') : 'Ninguna',
    data['miedo-mayor'],
    data.rol, data.presion,
    data.personalidad.length ? data.personalidad.join(' | ') : 'No indicada',
    data.motivo, data.grupo, data.exp, now
  ];
  const escape = v => '"' + String(v || '').replace(/"/g, '""') + '"';
  const csv = [headers.map(escape).join(','), values.map(escape).join(',')].join('\n');
  const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  const fname = 'moira_' + (data.nombre || 'participante').replace(/\s+/g,'_').toLowerCase().replace(/[^a-z0-9_]/g,'') + '_' + Date.now() + '.csv';
  a.download = fname;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}




